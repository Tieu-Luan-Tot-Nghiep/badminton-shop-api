# Example .env file for docker-compose (do NOT commit this file to git)

# RabbitMQ (for local dev/test)
RABBITMQ_DEFAULT_USER=your_rabbitmq_user
RABBITMQ_DEFAULT_PASS=your_rabbitmq_password
# For app: set RABBITMQ_ADDRESSES to connect to local rabbitmq-local container
# Example:
RABBITMQ_ADDRESSES=amqp://your_rabbitmq_user:your_rabbitmq_password@rabbitmq-local:5672

# PostgreSQL (used by docker-compose and CI/CD deploy)
POSTGRES_DB=badminton_shop
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me
# Optional explicit app DB variables (if omitted, compose derives from POSTGRES_* values)
# DB_URL=jdbc:postgresql://postgres:5432/badminton_shop
# DB_USERNAME=postgres
# DB_PASSWORD=change_me

# Public domain for links inside outgoing emails
APP_URL=https://shuttlex.io.vn

# Redis
REDIS_PASSWORD=your_redis_password

# Add other sensitive variables as needed
