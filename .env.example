# Example .env file for docker-compose (do NOT commit this file to git)

# RabbitMQ (for local dev/test)
RABBITMQ_DEFAULT_USER=your_rabbitmq_user
RABBITMQ_DEFAULT_PASS=your_rabbitmq_password
# For app: set RABBITMQ_ADDRESSES to connect to local rabbitmq-local container
# Example:
RABBITMQ_ADDRESSES=amqp://your_rabbitmq_user:your_rabbitmq_password@rabbitmq-local:5672

# Redis
REDIS_PASSWORD=your_redis_password

# Add other sensitive variables as needed
