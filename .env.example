# Example environment variables for local docker-compose and Spring Boot app
# Copy this file to .env and update sensitive values.

# =========================
# Docker Compose - app
# =========================
CONTAINER_NAME=badmintion-shop
APP_IMAGE=badmintion-shop:latest
HOST_PORT=80
CONTAINER_PORT=8080

# =========================
# PostgreSQL (compose + app)
# =========================
POSTGRES_DB=badminton_shop
POSTGRES_USER=your_postgres_user
POSTGRES_PASSWORD=your_postgres_password
DB_URL=jdbc:postgresql://postgres:5432/badminton_shop
DB_USERNAME=your_postgres_user
DB_PASSWORD=your_postgres_password

# =========================
# MongoDB (compose + app)
# =========================
MONGO_INITDB_ROOT_USERNAME=your_mongo_root_user
MONGO_INITDB_ROOT_PASSWORD=your_mongo_root_password
MONGO_INITDB_DATABASE=badminton_shop
MONGO_DB_CONNECT_STRING=mongodb://your_mongo_root_user:your_mongo_root_password@mongodb:27017/badminton_shop?authSource=admin

# =========================
# RabbitMQ
# =========================
RABBITMQ_DEFAULT_USER=your_rabbitmq_user
RABBITMQ_DEFAULT_PASS=your_rabbitmq_password
RABBITMQ_ADDRESSES=amqp://your_rabbitmq_user:your_rabbitmq_password@rabbitmq-local:5672

# =========================
# Redis
# =========================
REDIS_HOST=redis-local
REDIS_PORT=6379
REDIS_USERNAME=default
REDIS_PASSWORD=your_redis_password
REDIS_CONTAINER_PASSWORD=your_redis_password
REDIS_SSL_ENABLED=false
CART_REDIS_TTL_DAYS=7

# =========================
# Email
# =========================
EMAIL_USERNAME=your_email@gmail.com
EMAIL_PASSWORD=your_app_password

# =========================
# Auth rate limit
# =========================
AUTH_FORGOT_PASSWORD_COOLDOWN_SECONDS=60
AUTH_FORGOT_PASSWORD_MAX_REQUESTS=3
AUTH_FORGOT_PASSWORD_WINDOW_SECONDS=300
AUTH_RESEND_VERIFICATION_COOLDOWN_SECONDS=60
AUTH_RESEND_VERIFICATION_MAX_REQUESTS=3
AUTH_RESEND_VERIFICATION_WINDOW_SECONDS=300

# =========================
# Shipping (GHN)
# =========================
GHN_BASE_URL=https://dev-online-gateway.ghn.vn/shiip/public-api
GHN_TOKEN=
GHN_SHOP_ID=0
GHN_FROM_DISTRICT_ID=0
GHN_SERVICE_TYPE_ID=2
GHN_DEFAULT_WEIGHT_GRAMS=1000
GHN_DEFAULT_LENGTH_CM=35
GHN_DEFAULT_WIDTH_CM=10
GHN_DEFAULT_HEIGHT_CM=5
GHN_CALLBACK_AUTH_TOKEN=

# =========================
# OAuth2 social login
# =========================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# =========================
# Firebase
# =========================
FIREBASE_CONFIG_JSON=

# =========================
# VNPay
# =========================
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=

# =========================
# AWS S3
# =========================
AWS_S3_BUCKET=
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
AWS_REGION=ap-southeast-1

# =========================
# App URL
# =========================
APP_URL=https://shuttlex.io.vn

# =========================
# Elasticsearch
# =========================
ELASTICSEARCH_URIS=http://elasticsearch:9200
ELASTICSEARCH_API_KEY=
ELASTICSEARCH_PRODUCTS_INDEX=products
ELASTICSEARCH_CHAT_HISTORY_INDEX=chat_history

# =========================
# CLIP / Gemini
# =========================
CLIP_SERVICE_URL=https://linhhoai1603-badminton-shop.hf.space/embed/image
GEMINI_BASE_URL=https://generativelanguage.googleapis.com
GEMINI_MODEL=gemini-2.0-flash
